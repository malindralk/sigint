# Application
APP_ENV=development
DEBUG=true

# Database - SQLite (for local development)
DATABASE_URL=sqlite+aiosqlite:///./sigint.db

# Database - PostgreSQL with pgvector (for production)
# DATABASE_URL=postgresql+asyncpg://sigint:sigint_secret@localhost:5432/sigint
# DB_USER=sigint
# DB_PASSWORD=sigint_secret
# DB_NAME=sigint
# DB_PORT=5432

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Content path (relative to backend directory)
CONTENT_PATH=../content

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Security (change in production!)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# OAuth (for later phases)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dev-only manual login (set DEV_LOGIN_ENABLED=true for local dev ONLY)
DEV_LOGIN_ENABLED=false
DEV_LOGIN_EMAIL=
DEV_LOGIN_PASSWORD=
