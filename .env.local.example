# MALINDRA PHASE 2 — Environment Variables
# Copy this to .env.local and fill in your values.

# Site URL (used for sitemap, OG, RSS)
NEXT_PUBLIC_SITE_URL=https://malindra.lk

# FastAPI backend URL (used by lib/blog-data.ts at build time)
FASTAPI_URL=http://localhost:8000

# API URL for client-side (newsletter form)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Phase 2: Newsletter provider (optional — used by backend/newsletter.py)
# RESEND_API_KEY=re_...
# RESEND_AUDIENCE_ID=...

# Phase 2: Lighthouse CI (optional — used in GitHub Actions)
# LHCI_GITHUB_APP_TOKEN=...
